{% extends "layouts/PINS.html" %}

{% set title = 'LPA questionnaire' %}
{% set pageName = title + ' - Planning Inspectorate'%}

{% macro documentsValue(docs) %}
  {% if docs and docs.length %}
    <ul class="govuk-list govuk-list--bullet">
      {% for doc in docs %}
        <li>
          <a class="govuk-link" href="{{ doc.href }}">{{ doc.label }}</a>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    No documents
  {% endif %}
{% endmacro %}

{% macro yesNoWithDetail(answer, detail) %}
  {% if detail %}
    <p class="govuk-body govuk-!-margin-bottom-1">{{ answer }}</p>
    <p class="govuk-body govuk-!-margin-bottom-0">{{ detail }}</p>
  {% else %}
    {{ answer }}
  {% endif %}
{% endmacro %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <span class="govuk-caption-l">Appeal 2110166</span>
      <h1 class="govuk-heading-l">
        {{ title }}
      </h1>

    </div>
    <div class="govuk-grid-column-full">
      {% include "/includes/appeal-content/lpa-s78-questionnaire-meta--2026" %}

      {# ------------------------------
         1. Constraints, designations and other issues
         ------------------------------ #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">1. Constraints, designations and other issues</h2>
        </div>
        <div class="govuk-summary-card__content">

          {% set constraintsRows = [
            {
              key: {
                text: "Is planning appeal the correct type of appeal?"
              },
              value: {
                text: data['correctAppealType'] or "Yes"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.correctAppealType
                } ]
              }
            },
            {
              key: {
                text: "Does the development change a listed building?"
              },
              value: {
                text: data['changesListedBuilding'] or "No"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.changesListedBuilding
                } ]
              }
            },
            {
              key: {
                text: "Does the development affect the setting of listed buildings?"
              },
              value: {
                text: data['affectsSettingOfListedBuildings'] or "No"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.affectsSettingOfListedBuildings
                } ]
              }
            },
            {
              key: {
                text: "Would the development affect a scheduled monument?"
              },
              value: {
                text: data['scheduledMonument'] or "Yes"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.scheduledMonument
                } ]
              }
            },
            {
              key: {
                text: "Conservation area map and guidance"
              },
              value: {
                html: documentsValue(data['conservationAreaDocs'] or []) | safe
              },
              actions: {
                items: [ {
                  text: "Add",
                  href: lpaq.links.constraints.conservationAreaDocs
                } ]
              }
            },
            {
              key: {
                text: "Would the development affect a protected species?"
              },
              value: {
                text: data['protectedSpecies'] or "Yes"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.protectedSpecies
                } ]
              }
            },
            {
              key: {
                text: "Green belt"
              },
              value: {
                text: data['greenBelt'] or "Yes"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.greenBelt
                } ]
              }
            },
            {
              key: {
                text: "Is the site in a national landscape?"
              },
              value: {
                text: data['nationalLandscape'] or "Yes"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.nationalLandscape
                } ]
              }
            },
            {
              key: {
                text: "Is the development in, near or likely to affect any designated sites?"
              },
              value: {
                html:
                  yesNoWithDetail(
                    data['designatedSitesAnswer'] or "Yes",
                    data['designatedSitesDetail'] or "• SPA Ramsar (Ramsar special protection area)\n• Other: A custom value"
                  ) | safe
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.designatedSites
                } ]
              }
            },
            {
              key: {
                text: "Tree Preservation Order"
              },
              value: {
                html: documentsValue(data['tpoDocs'] or []) | safe
              },
              actions: {
                items: [ {
                  text: "Add",
                  href: lpaq.links.constraints.tpoDocs
                } ]
              }
            },
            {
              key: {
                text: "Does the development relate to anyone claiming to be a Gypsy or Traveller?"
              },
              value: {
                text: data['gypsyTraveller'] or "No"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.constraints.gypsyTraveller
                } ]
              }
            },
            {
              key: {
                text: "Definitive map and statement extract"
              },
              value: {
                html: documentsValue(data['definitiveMapDocs'] or []) | safe
              },
              actions: {
                items: [ {
                  text: "Add",
                  href: lpaq.links.constraints.definitiveMapDocs
                } ]
              }
            }
          ] %}

          {{ govukSummaryList({
            rows: constraintsRows
          }) }}

        </div>
      </div>

      {# ------------------------------
