              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.eia.developmentCategory
                } ]
              }
            },
            {
              key: {
                text: "Did your screening opinion say the development needed an environmental statement?"
              },
              value: {
                text: data['needsEnvironmentalStatement'] or "Yes"
              },
              actions: {
                items: [ {
                  text: "Change",
                  href: lpaq.links.eia.needsEnvironmentalStatement
                } ]
              }
            },
            {
              key: {
                text: "Environmental statement and supporting information"
              },
              value: {
                html: documentsValue(data['environmentalStatementDocs'] or []) | safe
              },
              actions: {
                items: [ {
                  text: "Add",
                  href: lpaq.links.eia.environmentalStatementDocs
                } ]
              }
            },
            {
              key: {
                text: "Screening opinion documents"
              },
              value: {
                html: documentsValue(data['screeningOpinionDocs'] or []) | safe
              },
              actions: {
                items: [ {
                  text: "Add",
                  href: lpaq.links.eia.screeningOpinionDocs
                } ]
              }
            },
            {
              key: {
                text: "Screening direction documents"
              },
              value: {
                html: documentsValue(data['screeningDirectionDocs'] or []) | safe
              },
              actions: {
                items: [ {
                  text: "Add",
                  href: lpaq.links.eia.screeningDirectionDocs
                } ]
              }
            },
            {
              key: {
                text: "Scoping opinion documents"
              },
              value: {
                html: documentsValue(data['scopingOpinionDocs'] or []) | safe
              },
              actions: {
                items: [ {
                  text: "Add",
                  href: lpaq.links.eia.scopingOpinionDocs
                } ]
              }
            }
          ] %}

          {{ govukSummaryList({
            rows: eiaRows
          }) }}

        </div>
      </div>

      {# ------------------------------
         3. Notifying relevant parties
         ------------------------------ #}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">3. Notifying relevant parties</h2>
